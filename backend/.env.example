# ===========================================================
# iOS Apps Platform — Environment Configuration
# ===========================================================
# Copy this file to .env and adjust for your environment.
#
# Quick links:
#   • Local dev (Docker):    docker-compose up -d
#   • Production:            docs/DEPLOY_VERCEL_RAILWAY.md
# ===========================================================

# ---------------- App ----------------
APP_NAME="iOS Apps Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api.up.railway.app
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=info

# ---------------- Database (Railway auto-provides) ----------------
DB_CONNECTION=mysql
# On Railway, set these in the service Variables tab; they'll be
# injected as MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT:-3306}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# ---------------- Redis (Railway auto-provides) ----------------
REDIS_HOST=${REDISHOST}
REDIS_PORT=${REDISPORT:-6379}
REDIS_PASSWORD=${REDISPASSWORD:-}
REDIS_CLIENT=phpredis

# ---------------- Cache / Queue / Session ----------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ---------------- JWT ----------------
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_BLACKLIST_ENABLED=true

# ---------------- Storage ----------------
# Recommended on Railway: use Cloudflare R2 (free egress)
# Set to "local" only for testing
FILESYSTEM_DISK=r2
PUBLIC_DISK=r2
STORAGE_PATH_PREFIX=apps

# ---------------- Cloudflare R2 (recommended) ----------------
# 1. Create a bucket at dash.cloudflare.com
# 2. Generate R2 API tokens
# 3. Set the public bucket URL (R2 > Settings > Public Development URL)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=ios-platform-apps
AWS_URL=https://your-bucket.r2.dev
AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------- Upload limits ----------------
UPLOAD_MAX_SIZE_MB=512
UPLOAD_IPA_MIME_CHECK=true
UPLOAD_IPA_EXT_CHECK=true

# ---------------- Rate limiting ----------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ADMIN_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=10

# ---------------- Manifest / Install ----------------
# Must be the PUBLIC URL of the backend (used in itms-services links)
MANIFEST_BASE_URL=https://your-api.up.railway.app
IPA_DOWNLOAD_TOKEN_TTL_HOURS=24

# ---------------- CORS ----------------
# Add your Vercel domain(s) here, comma-separated
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
CORS_SUPPORTS_CREDENTIALS=true

# ---------------- Frontend URL ----------------
# Used for email links, redirects, etc.
FRONTEND_URL=https://your-app.vercel.app

# ---------------- Mail (use a real provider in prod) ----------------
MAIL_MAILER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@ios-platform.app"
MAIL_FROM_NAME="${APP_NAME}"
